<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
  <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>

  <!--
    BackChannelLogoutSessionDestroyIT runs Vaadin in production mode without
    a frontend bundle, so attempts to render the test route fail noisily after
    the VaadinSession has already been bound (which is all the test cares
    about). Silence those branches so the surefire output stays clean.
  -->
  <logger name="com.vaadin.flow.internal.FrontendUtils" level="OFF"/>
  <logger name="com.vaadin.flow.server.DefaultErrorHandler" level="OFF"/>
  <logger name="org.apache.catalina.core.ContainerBase.[Tomcat].[localhost].[/].[springServlet]" level="OFF"/>
  <logger name="org.apache.catalina.core.ContainerBase.[Tomcat].[localhost].[/].[dispatcherServlet]" level="OFF"/>
</configuration>
